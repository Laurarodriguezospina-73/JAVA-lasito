static class ConfettiPanel extends javax.swing.JPanel {
    private final java.util.List<int[]> particulas = new java.util.ArrayList<>();
    private javax.swing.Timer timer;

    public ConfettiPanel(int ancho, int alto) {
        setOpaque(false);
        setBounds(0, 0, ancho, alto);
        java.util.Random rand = new java.util.Random();

        for (int i = 0; i < 80; i++) {
            particulas.add(new int[]{
                rand.nextInt(ancho),
                rand.nextInt(alto) * -1,
                rand.nextInt(3) + 2,
                rand.nextInt(6) - 3,
                rand.nextInt(360),
                rand.nextInt(5),
                rand.nextInt(8) + 6,
            });
        }

        timer = new javax.swing.Timer(30, e -> {
            for (int[] p : particulas) {
                p[1] += p[2];
                p[0] += p[3];
                p[4] += 5;
                if (p[1] > alto) p[1] = -20;
            }
            repaint();
        });
        timer.start();
    }

    public void detener() {
        timer.stop();
    }

    @Override
    protected void paintComponent(java.awt.Graphics g) {
        super.paintComponent(g);
        java.awt.Color[] colores = {
            java.awt.Color.RED,
            new java.awt.Color(255, 220, 0),
            java.awt.Color.GREEN,
            java.awt.Color.MAGENTA,
            java.awt.Color.CYAN
        };
        java.awt.Graphics2D g2 = (java.awt.Graphics2D) g;
        for (int[] p : particulas) {
            g2.setColor(colores[p[5]]);
            g2.rotate(Math.toRadians(p[4]), p[0], p[1]);
            g2.fillRect(p[0], p[1], p[6], p[6] / 2);
            g2.rotate(-Math.toRadians(p[4]), p[0], p[1]);
        }
    }
