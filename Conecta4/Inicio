        private void mostrarReglas() {
        String reglas = "REGLAS DEL CONECTA 4\n\n"
            + "OBJETIVO DEL JUEGO\n"
            + "Ser el primer jugador en conectar 4 fichas\n"
            + "del mismo color en línea recta.\n\n"
            
            + "CÓMO JUGAR\n"
            +"Haz clic en cualquier columna del tablero.\n"
            +"Tu ficha caerá hasta la posición más baja disponible.\n"   
            +"Los jugadores alternan turnos automáticamente.\n"
            +"Gana quien primero conecte 4 fichas.\n\n"
            
            + "JUGADORES\n"
            + "Jugador 1: Fichas de color ROJO\n"
            + "Jugador 2: Fichas de color AMARILLO\n\n"
            
            + "FORMAS DE GANAR\n"
            + "✓ Horizontal: 4 fichas seguidas en una fila\n"
            + "✓ Vertical: 4 fichas seguidas en una columna\n"
            + "✓ Diagonal: 4 fichas seguidas en diagonal\n\n"
            
            + "EMPATE\n"
            + "Si el tablero se llena sin que nadie conecte 4,\n"
            + "la partida termina en empate.\n\n"
            
            + "CRONÓMETRO\n"
            + "Se muestra el tiempo total de cada ronda.\n"
            + "El cronómetro se reinicia automáticamente.\n\n"
            
            + "QUE GANE EL MEJOR!";
        
        JOptionPane.showMessageDialog(this, 
            reglas, 
            "📖 Reglas del Conecta 4", 
            JOptionPane.INFORMATION_MESSAGE);
    }

