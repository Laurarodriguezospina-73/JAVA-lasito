    private void jButton1ActionPerformed(java.awt.event.ActionEvent evt) {                                         
    String nombreJ1 = jTextField1.getText().trim();
    String nombreJ2 = jTextField2.getText().trim();

    if (nombreJ1.isEmpty() || nombreJ2.isEmpty()) {
        javax.swing.JOptionPane.showMessageDialog(this, "¡Error! Ambos jugadores deben tener un nombre.");
    } else {
        // Abre el juego pasando los nombres
        new ConnectFour(nombreJ1, nombreJ2);
        this.dispose(); // Cierra la ventana de registro
    }
    }                                        

